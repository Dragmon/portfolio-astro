---
interface Image {
  url: string;
  alt: string;
}

interface Props {
  images: Image[];
  delay?: number;
}

const { images, delay = 2000 } = Astro.props;

---

<div class="embla">
  <div class="embla__viewport">
    <div class="embla__container">
      {
        images.map((image) => (
          <div class="embla__slide">
            <img src={image.url} alt={image.alt} loading="lazy" />
          </div>
        ))
      }
    </div>
  </div>

  <!-- Botones de navegación -->
  <button class="embla__btn embla__prev" aria-label="Anterior">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <path d="M15 18l-6-6 6-6" />
    </svg>
  </button>
  <button class="embla__btn embla__next" aria-label="Siguiente">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <path d="M9 18l6-6-6-6" />
    </svg>
  </button>

  <!-- Indicadores de puntos -->
  <div class="embla__dots">
    {images.map((_, i) => <button class="embla__dot" data-index={i} aria-label={`Slide ${i + 1}`} />)}
  </div>
</div>

<style>
  .embla {
    position: relative;
    overflow: hidden;
    border-radius: 0.75rem;
  }

  .embla__viewport {
    overflow: hidden;
    width: 100%;
  }

  .embla__container {
    display: flex;
    touch-action: pan-y;
  }

  .embla__slide {
    flex: 0 0 100%;
    min-width: 0;
  }

  .embla__slide img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    border-radius: 0.75rem;
  }

  .embla__btn {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background: rgb(from var(--color-space-500) r g b / 0.60);
    backdrop-filter: blur(6px);
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 50%;
    width: 2.5rem;
    height: 2.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    color: white;
    transition: background 0.2s;
    z-index: 10;
  }

  .embla__btn:hover {
    background: rgb(from var(--color-space-500) r g b / 0.40);
  }

  .embla__btn svg {
    width: 1.2rem;
    height: 1.2rem;
  }

  .embla__prev { left: 0.75rem; }
  .embla__next { right: 0.75rem; }

  .embla__dots {
    position: absolute;
    bottom: 0.75rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 0.4rem;
  }

  .embla__dot {
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.4);
    border: none;
    cursor: pointer;
    padding: 0;
    transition: background 0.2s, transform 0.2s;
  }

  .embla__dot.is-active {
    background: white;
    transform: scale(1.3);
  }
</style>

<script>
  import EmblaCarousel from "embla-carousel";
  import Autoplay from "embla-carousel-autoplay";

  const emblaNode = document.querySelector(".embla__viewport") as HTMLElement;
  const prevBtn = document.querySelector(".embla__prev") as HTMLElement;
  const nextBtn = document.querySelector(".embla__next") as HTMLElement;
  const dots = document.querySelectorAll(".embla__dot");

  const embla = EmblaCarousel(
    emblaNode,
    { loop: true },
    [Autoplay({ delay: 2000, stopOnInteraction: false, stopOnMouseEnter: true })]
  );

  // Navegación
  prevBtn.addEventListener("click", () => embla.scrollPrev());
  nextBtn.addEventListener("click", () => embla.scrollNext());

  // Sincronizar dots con el slide activo
  const updateDots = () => {
    const index = embla.selectedScrollSnap();
    dots.forEach((dot, i) => {
      dot.classList.toggle("is-active", i === index);
    });
  };

  embla.on("select", updateDots);
  updateDots();
</script>