---
import Button from "../ui/Button.astro";
import Heading from "../ui/Heading.astro";
import Tools from "../portfolio/Tools.astro";
import { Icon } from "astro-icon/components";
import Hobbies from "../portfolio/Hobbies.astro";
import { getCollection } from "astro:content";

const [staticData] = await getCollection("staticData");
const {
  profileAlt,
  profileLink,
  profileImage,
  profileName,
  profileTitle,
  email,
  emailIconName,
  github,
  portfolioImage,
  contactSectionButtonText,
} = staticData.data;
---

<section
  class="scroll-m-16 px-8 max-sm:px-4 py-8"
  id="home"
  aria-label="Professional profile and introduction"
>
  <div
    class="mx-auto mb-4 h-96 w-full max-w-7xl rounded-2xl bg-linear-to-r from-space-300 dark:from-space-600 to-space-50 dark:to-space-200/5 hover:to-space-300/30 dark:hover:to-space-600/30 p-[.2rem] max-md:h-auto"
  >
    <div
      class="group relative z-0 flex h-full items-center justify-center gap-8 overflow-hidden rounded-2xl bg-linear-to-tr from-space-100 to-white p-4 transition-all hover:shadow-[0_10px_50px_rgba(47,167,201,0.25)] dark:bg-linear-to-r dark:from-space-900 dark:to-space-950 dark:overflow-hidden max-md:w-full max-md:gap-3 max-lg:gap-2 max-sm:flex-col dark:before:bg-[radial-gradient(circle,rgba(47,167,201)_0,rgba(7,14,26)_100%)] before:bg-[radial-gradient(circle,rgba(142,216,243))_0,rgba(214,243,255))_100%)] before:absolute before:left-65 before:top-10 before:h-[40%] before:aspect-square before:rounded-full before:blur-3xl before:opacity-80 before:-z-10 before:transition hover:before:animate-pulse"
    >
      <div class="aspect-square h-4/5 max-md:size-32">
        <div
          class="group-hover:scale-105 relative z-10 flex w-full cursor-pointer items-center overflow-hidden rounded-full p-[2px] transition-all duration-500"
        >
          <div
            class="absolute inset-0 h-full w-full rounded-fullfrom-transparent to-metal-500 dark:from-transparent f dark:to-space-300 animate-rotate-border bg-conic/[from_var(--border-angle)]"
          >
          </div>
          <div class="relative z-20 flex w-full rounded-full bg-space-900">
            <div
              class="w-full aspect-square rounded-full bg-center bg-cover"
              style={`background-image: url(${profileImage})`}
              aria-label={profileAlt}
            >
              <a
                href={profileLink}
                class="flex h-full w-full"
                aria-label="View about me page"></a>
            </div>
          </div>
        </div>
      </div>

      <div
        class="flex h-full w-7/12 flex-col justify-center gap-4 p-4 max-md:w-full max-md:gap-2"
      >
        <h1
          class="text-4xl font-black leading-none text-blacktext dark:text-white max-xl:text-3xl max-lg:text-2xl max-sm:text-center"
        >
          {profileName} 👋
        </h1>
        <p
          class="mb-0 text-lg font-semibold leading-8 text-blacktext dark:text-gray-200 max-xl:text-base"
        >
          <span
            class="bg-linear-to-r from-metal-500 to-space-500 bg-clip-text font-black text-transparent dark:from-metal-300 dark:to-space-200"
            >{profileTitle}</span
          > con <span
            class="bg-linear-to-r from-metal-500 to-space-500 bg-clip-text font-black text-transparent dark:from-metal-300 dark:to-space-200"
            >7 años de experiencia</span
          >,algunas de las tecnologías que manejo son JavaScript, ReactJS, HTML, CSS, WordPress, entre otras.
        </p>
        <p class="mb-0 text-lg font-semibold leading-8 text-blacktext dark:text-gray-200 max-xl:text-base">
          <span>
            Me he desempeñado en el rubro bancario como en el de marketing digital.
          </span>
          <span>
            Soy autodidacta, busco adaptarme rápidamente a los cambios y dispuesto a aprender nuevas tecnologías.
          </span>
        </p>

        <div class="flex gap-4 max-sm:flex-col max-sm:items-center">
          <Button
            link={"mailto:" + email}
            text={contactSectionButtonText}
            iconName={emailIconName}
            isExternal={true}
          />
        </div>
      </div>
    </div>
  </div>
</section>
